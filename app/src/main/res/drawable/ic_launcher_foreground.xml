<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing Drop Shadow for the Main Ring -->
    <path
        android:pathData="M54,32 A22,22 0,1,1,53.9,32 Z"
        android:strokeWidth="11"
        android:strokeColor="#3F000000" />

    <!-- 1. The Main Life Preserver Ring -->
    <path
        android:pathData="M54,32 A22,22 0,1,1,53.9,32 Z"
        android:strokeWidth="9"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="32"
                android:startY="32"
                android:endX="76"
                android:endY="76"
                android:type="linear">
                <item android:offset="0" android:color="#F97316" /> <!-- Rescue Orange -->
                <item android:offset="1" android:color="#F59E0B" /> <!-- Amber Gold -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- 2. White Strap Accents (Top, Bottom, Left, Right) -->
    <path
        android:pathData="M54,26 L54,38"
        android:strokeWidth="7.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <path
        android:pathData="M54,70 L54,82"
        android:strokeWidth="7.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <path
        android:pathData="M26,54 L38,54"
        android:strokeWidth="7.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <path
        android:pathData="M70,54 L82,54"
        android:strokeWidth="7.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />

    <!-- 3. Central Premium Hourglass (Sand Clock) tilted to the right -->
    <group
        android:rotation="15"
        android:pivotX="54"
        android:pivotY="54">
        <!-- Hourglass Glass Body and Outer Frame -->
        <path
            android:pathData="M 44,45 L 64,45 C 62,50 57,51 57,54 C 57,57 62,58 64,63 L 44,63 C 46,58 51,57 51,54 C 51,51 46,50 44,45 Z"
            android:strokeWidth="1.5"
            android:strokeColor="#FFFBEB" />

        <!-- Top and Bottom Plates of the Hourglass -->
        <path
            android:pathData="M 41,43 L 67,43 L 67,46 L 41,46 Z"
            android:fillColor="#FCD34D" />
        <path
            android:pathData="M 41,62 L 67,62 L 67,65 L 41,65 Z"
            android:fillColor="#F59E0B" />

        <!-- Top Sand (Filling top chamber) -->
        <path
            android:pathData="M 46,47 L 62,47 C 60,51 55,52 54,53 C 53,52 48,51 46,47 Z"
            android:fillColor="#FDE68A" />

        <!-- Bottom Sand (Accumulating at the bottom) -->
        <path
            android:pathData="M 54,55 L 57,58 C 61,61 63,62 63,62.5 L 45,62.5 C 45,62 47,61 51,58 Z"
            android:fillColor="#F59E0B" />

        <!-- Trickling Sand Stream -->
        <path
            android:pathData="M 53.5,52 L 54.5,52 L 54.5,62 L 53.5,62 Z"
            android:fillColor="#FCD34D" />
    </group>
</vector>
